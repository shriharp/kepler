<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Keplerv0" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand colour: stellar blue -->
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorPrimaryContainer">@color/accent_blue_dim</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <!-- Secondary / selection highlight used by NavigationView item pills -->
        <item name="colorSecondaryContainer">@color/nav_selected_bg</item>
        <item name="colorOnSecondaryContainer">@color/nav_selected_text</item>

        <!-- Surface colours -->
        <item name="colorSurface">@color/drawer_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/drawer_bg</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Window chrome -->
        <item name="android:windowBackground">@color/space_black</item>
        <item name="android:statusBarColor">@color/header_bg</item>
        <item name="android:navigationBarColor">@color/space_black</item>
        <item name="android:windowLightStatusBar" tools:ignore="NewApi">false</item>
    </style>

    <style name="Theme.Keplerv0" parent="Base.Theme.Keplerv0" />

</resources>