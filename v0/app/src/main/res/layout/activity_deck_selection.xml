<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="16dp">

    <!-- Title + EP balance row -->
    <LinearLayout
        android:id="@+id/ll_title_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Choose Your Cards"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Energy Points balance -->
        <TextView
            android:id="@+id/tv_ep_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ 0 EP"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>

    <!-- Tab row: My Cards | Shop -->
    <LinearLayout
        android:id="@+id/ll_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/ll_title_row">

        <Button
            android:id="@+id/btn_tab_collection"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="My Cards"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_tab_shop"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="⚡ Buy Cards"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Collection RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_deck_selection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btn_confirm_deck"
        app:layout_constraintTop_toBottomOf="@id/ll_tabs" />

    <!-- Shop RecyclerView (hidden by default) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_shop"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btn_confirm_deck"
        app:layout_constraintTop_toBottomOf="@id/ll_tabs" />

    <Button
        android:id="@+id/btn_confirm_deck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm Deck (0/2)"
        android:enabled="false"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>