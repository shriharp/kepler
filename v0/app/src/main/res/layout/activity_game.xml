<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_quiz"
    android:padding="16dp"
    tools:context=".GameActivity">

    <!-- Animated Orbs Background -->
    <com.prj.keplerv0.quiz.FloatingOrbsView
        android:id="@+id/floating_orbs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top scrim -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/scrim_top"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bottom scrim -->
    <View
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="@drawable/scrim_bottom"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Turn Indicator -->
    <TextView
        android:id="@+id/tv_turn_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waiting..."
        android:textColor="@color/accent_gold"
        android:textSize="20sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- AI/Opponent Card and Stats -->
    <LinearLayout
        android:id="@+id/ll_ai_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tv_turn_indicator">

        <!-- AI Card Graphic -->
        <LinearLayout
            android:layout_width="100dp"
            android:layout_height="140dp"
            android:background="@drawable/bg_game_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x2726;"
                android:textColor="@color/accent_gold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_ai_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Opponent"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:gravity="center"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- AI Stats -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPPONENT HP"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.1" />

            <ProgressBar
                android:id="@+id/pb_ai_hp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="4dp"
                android:max="20"
                android:progress="20"
                android:progressTint="#FF4444" />

            <TextView
                android:id="@+id/tv_ai_hp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20/20"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="OPPONENT STAMINA"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.1" />

            <ProgressBar
                android:id="@+id/pb_ai_stamina"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:max="10"
                android:progress="0"
                android:progressTint="@color/accent_blue" />

            <TextView
                android:id="@+id/tv_ai_stamina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/10"
                android:textColor="@color/accent_blue"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Effect Animation Container (replaces ScrollView Log) -->
    <FrameLayout
        android:id="@+id/fl_effect_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/ll_ai_container"
        app:layout_constraintBottom_toTopOf="@id/ll_user_container"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_effect_anim"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text=""
            android:textColor="@color/accent_gold"
            android:textSize="24sp"
            android:fontFamily="sans-serif-light"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:visibility="invisible"
            android:elevation="10dp"/>

        <ScrollView
            android:id="@+id/sv_log"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_game_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="" />
        </ScrollView>
    </FrameLayout>

    <!-- User Card and Stats -->
    <LinearLayout
        android:id="@+id/ll_user_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/btn_swap_card">

        <!-- User Stats -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="16dp"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR HP"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.1" />

            <ProgressBar
                android:id="@+id/pb_user_hp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="4dp"
                android:max="20"
                android:progress="20"
                android:progressTint="#00FFAA" />

            <TextView
                android:id="@+id/tv_user_hp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20/20"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="YOUR STAMINA"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.1" />

            <ProgressBar
                android:id="@+id/pb_user_stamina"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:max="10"
                android:progress="0"
                android:progressTint="@color/accent_blue" />

            <TextView
                android:id="@+id/tv_user_stamina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/10"
                android:textColor="@color/accent_blue"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- User Card Graphic -->
        <LinearLayout
            android:layout_width="100dp"
            android:layout_height="140dp"
            android:background="@drawable/bg_game_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x2726;"
                android:textColor="@color/accent_blue"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_card_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Player"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"/>

            <TextView
                android:id="@+id/tv_card_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ATK: ?\nDEF: ?"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btn_swap_card"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="12dp"
        android:text="SWAP ACTIVE CARD (1 STAMINA)"
        android:textColor="@color/accent_gold"
        android:textSize="11sp"
        android:letterSpacing="0.05"
        android:background="@drawable/bg_ability_button"
        app:layout_constraintBottom_toTopOf="@id/ll_abilities_container" />

    <!-- Abilities Container -->
    <LinearLayout
        android:id="@+id/ll_abilities_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_actions">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/btn_atk1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="8dp"
                android:text="Atk 1"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:background="@drawable/bg_ability_button"/>
            <Button
                android:id="@+id/btn_atk2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:text="Atk 2"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:background="@drawable/bg_ability_button"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/btn_def1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Def 1"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:background="@drawable/bg_ability_button"/>
            <Button
                android:id="@+id/btn_def2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Def 2"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:background="@drawable/bg_ability_button"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom action row: EP display + Emergency + End Turn -->
    <LinearLayout
        android:id="@+id/ll_bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Energy Points balance -->
        <TextView
            android:id="@+id/tv_energy_points_battle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ 0 EP"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light"
            android:paddingStart="4dp"
            android:paddingEnd="8dp" />

        <!-- Emergency Recovery -->
        <Button
            android:id="@+id/btn_emergency_recovery"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="⚡ Recovery"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:background="@drawable/bg_ability_button"
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />

        <!-- End Turn -->
        <Button
            android:id="@+id/btn_end_turn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="END TURN"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_ability_button" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>