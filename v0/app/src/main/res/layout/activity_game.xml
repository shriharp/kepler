<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="16dp"
    tools:context=".GameActivity">

    <!-- Turn Indicator -->
    <TextView
        android:id="@+id/tv_turn_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waiting..."
        android:textColor="#FFD700"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- AI/Opponent Stats -->
    <LinearLayout
        android:id="@+id/ll_ai_stats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_turn_indicator">

        <TextView
            android:id="@+id/tv_ai_hp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opponent HP: 50"
            android:textColor="#FF0000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_ai_energy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opponent Energy: 1"
            android:textColor="#0000FF"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_ai_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Opponent Card: ..."
        android:textColor="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_ai_stats" />

    <!-- Game Log -->
    <ScrollView
        android:id="@+id/sv_log"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="16dp"
        android:background="#1A1A1A"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_ai_card">

        <TextView
            android:id="@+id/tv_game_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initializing battle links...\n"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
    </ScrollView>

    <!-- Active Card Display (User) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_user_card"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#222222"
        app:cardCornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sv_log">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_card_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..."
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_card_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ATK: ? | DEF: ?"
                android:textColor="#FFD700" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- User Controls -->
    <LinearLayout
        android:id="@+id/ll_user_stats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/btn_swap_card"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_user_hp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your HP: 50"
            android:textColor="#00FF00"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_user_energy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Energy: 1"
            android:textColor="#0000FF"
            android:textSize="14sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_swap_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Swap Card (1 Energy)"
        app:layout_constraintBottom_toTopOf="@id/ll_abilities_container" />

    <LinearLayout
        android:id="@+id/ll_abilities_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/btn_end_turn">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btn_atk1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Atk 1"
                android:textSize="11sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <Button
                android:id="@+id/btn_atk2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Atk 2"
                android:textSize="11sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btn_def1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Def 1"
                android:textSize="11sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <Button
                android:id="@+id/btn_def2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Def 2"
                android:textSize="11sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btn_end_turn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="End Turn"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>