<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ══════════════════ MAIN CONTENT ══════════════════ -->
    <!-- The GL surface is added at index 0 programmatically (background layer).
         All overlay views declared here float above it. -->
    <FrameLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/space_black">

        <!-- Top scrim + title bar ─────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="@drawable/scrim_top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="20dp">

            <!-- Circular menu button -->
            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/btn_menu_bg"
                android:src="@drawable/ic_menu"
                android:padding="11dp"
                android:elevation="4dp"
                android:contentDescription="Open navigation menu" />

            <!-- App name + subtitle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KEPLER"
                    android:textColor="@color/text_primary"
                    android:textSize="19sp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stellar Navigator"
                    android:textColor="@color/accent_blue"
                    android:textSize="11sp"
                    android:letterSpacing="0.05" />

            </LinearLayout>

        </LinearLayout>

        <!-- Star info card (tap a star to show, tap card to dismiss) ─────── -->
        <LinearLayout
            android:id="@+id/star_info_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="110dp"
            android:background="@drawable/star_card_bg"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:elevation="8dp"
            android:visibility="gone">

            <!-- Gold accent glyph -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x2726;"
                android:textColor="@color/accent_gold"
                android:textSize="10sp" />

            <!-- Star name -->
            <TextView
                android:id="@+id/tv_star_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.04"
                android:layout_marginTop="2dp" />

            <!-- Dismiss hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TAP TO DISMISS"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Bottom HUD bar ──────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/bottom_hud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/scrim_bottom"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:gravity="center_vertical">

            <!-- Location column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCATION"
                    android:textColor="@color/text_secondary"
                    android:textSize="8sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tv_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Locating\u2026"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:background="@color/divider" />

            <!-- Visible stars column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VISIBLE"
                    android:textColor="@color/text_secondary"
                    android:textSize="8sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tv_star_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u2014 stars"
                    android:textColor="@color/accent_blue"
                    android:textSize="11sp"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:background="@color/divider" />

            <!-- Control mode column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTROL"
                    android:textColor="@color/text_secondary"
                    android:textSize="8sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tv_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gyroscope"
                    android:textColor="@color/accent_gold"
                    android:textSize="11sp"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- ══════════════════ NAVIGATION DRAWER ══════════════════ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="288dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/drawer_bg"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"
        app:itemTextColor="@color/text_primary"
        app:itemIconTint="@color/accent_blue" />

</androidx.drawerlayout.widget.DrawerLayout>